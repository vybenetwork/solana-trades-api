{
  "name": "solana-historical-trade-data-api",
  "version": "1.0.0",
  "description": "Solana historical trade data API demo — Vybe API",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "prestart": "npm run build:frontend"
  },
  "keywords": ["solana", "trades", "historical", "vybe", "api"],
  "license": "MIT",
  "dependencies": {
    "axios": "1.7.9",
    "dotenv": "16.4.5",
    "express": "4.21.1"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.10.1",
    "typescript": "5.6.3",
    "tsx": "4.19.2"
  },
  "engines": {
    "node": ">=20"
  }
}

